# ─── Combined server ─────────────────────────────────────────────────────────
PORT=8080

# ─── Shared ───────────────────────────────────────────────────────────────────
# Shared by all apps. Must be at least 64 characters.
# exam-creator requires exactly 64 characters.
COOKIE_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALLOWED_ORIGINS=http://localhost:8080
APP_ENV=development
MOCK_AUTH=false

# Single MongoDB connection string — used by all apps for sessions and users.
MONGODB_URI=mongodb://localhost:27017/team-board

# ─── Auth (GitHub OAuth) ──────────────────────────────────────────────────────
# All auth is handled globally at /api/auth/*.
# Register a GitHub OAuth App with the callback URL below.
GITHUB_APP_CLIENT_ID=your-github-client-id
GITHUB_APP_CLIENT_SECRET=your-github-client-secret
GITHUB_APP_REDIRECT_URL=http://localhost:8080/api/auth/callback/github
# GitHub App private key (PEM, use literal \n for newlines in one-line format)
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Optional
# SESSION_TTL_IN_S=43200
# LOG_LEVEL=info

# ─── exam-creator ────────────────────────────────────────────────────────────
# Two MongoDB connection strings (production + staging databases)
MONGODB_URI_PRODUCTION=mongodb://127.0.0.1:27017/exam-creator-production?directConnection=true
MONGODB_URI_STAGING=mongodb://127.0.0.1:27017/exam-creator-staging?directConnection=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Optional
# SENTRY_DSN=https://...@sentry.io/...
# SESSION_TTL_IN_S=7200
# REQUEST_BODY_SIZE_LIMIT=5242880
# REQUEST_TIMEOUT_IN_MS=11000

# ─── task-tracker ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
